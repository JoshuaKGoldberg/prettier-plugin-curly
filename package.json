{
	"name": "prettier-plugin-curly",
	"version": "0.4.1",
	"description": "Prettier plugin to enforce consistent brace style for all control statements. 🥌",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JoshuaKGoldberg/prettier-plugin-curly.git"
	},
	"license": "MIT",
	"author": {
		"name": "JoshuaKGoldberg",
		"email": "npm@joshuakgoldberg.com"
	},
	"type": "commonjs",
	"exports": {
		".": {
			"import": {
				"types": "./lib/index.d.mts",
				"default": "./lib/index.mjs"
			},
			"require": {
				"types": "./lib/index.d.cts",
				"default": "./lib/index.cjs"
			}
		}
	},
	"main": "lib/index.cjs",
	"files": [
		"lib/"
	],
	"scripts": {
		"build": "tsdown",
		"format": "prettier . --write",
		"lint": "eslint . --max-warnings 0",
		"lint:knip": "knip",
		"lint:md": "markdownlint \"**/*.md\" \".github/**/*.md\" --rules sentences-per-line",
		"lint:packages": "pnpm dedupe --check",
		"lint:spelling": "cspell \"**\" \".github/**/*\"",
		"prepare": "husky",
		"test": "vitest",
		"tsc": "tsc"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"devDependencies": {
		"@babel/types": "8.0.0",
		"@eslint-community/eslint-plugin-eslint-comments": "4.7.0",
		"@eslint/js": "10.0.1",
		"@release-it/conventional-changelog": "11.0.0",
		"@types/eslint-plugin-markdown": "2.0.2",
		"@types/node": "24.13.0",
		"@vitest/coverage-v8": "4.1.0",
		"@vitest/eslint-plugin": "1.6.1",
		"console-fail-test": "0.6.0",
		"create-typescript-app": "2.46.3",
		"cspell": "10.0.0",
		"eslint": "10.7.0",
		"eslint-plugin-jsdoc": "63.2.0",
		"eslint-plugin-jsonc": "3.3.0",
		"eslint-plugin-markdown": "5.1.0",
		"eslint-plugin-n": "18.2.0",
		"eslint-plugin-package-json": "0.88.0",
		"eslint-plugin-perfectionist": "5.10.0",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-yml": "3.6.0",
		"husky": "9.1.7",
		"knip": "6.27.0",
		"lint-staged": "17.1.0",
		"markdownlint": "0.41.0",
		"markdownlint-cli": "0.49.0",
		"prettier": "3.8.0",
		"prettier-plugin-packagejson": "3.0.0",
		"prettier-plugin-sh": "0.19.0",
		"release-it": "20.2.0",
		"sentences-per-line": "0.3.0",
		"tsdown": "0.22.0",
		"typescript": "6.0.2",
		"typescript-eslint": "8.64.0",
		"vitest": "4.1.0"
	},
	"peerDependencies": {
		"prettier": "^3"
	},
	"packageManager": "pnpm@11.15.0",
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"provenance": true
	}
}
